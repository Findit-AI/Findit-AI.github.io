---
import { t, type Locale } from '../i18n/runtime';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<section class="content-limit waitlist-page reveal">
  <article class="waitlist-panel surface">
    <header class="waitlist-head">
      <p class="section-kicker">{t(locale, 'waitlist_kicker')}</p>
      <h1>{t(locale, 'waitlist_heading')}</h1>
      <p>{t(locale, 'waitlist_subtitle')}</p>
    </header>

    <form class="waitlist-form" data-waitlist-form novalidate>
      <label class="waitlist-field">
        <span>{t(locale, 'waitlist_form_name_label')}</span>
        <input
          type="text"
          name="name"
          placeholder={t(locale, 'waitlist_form_name_placeholder') ?? ''}
          autocomplete="name"
        />
      </label>

      <label class="waitlist-field">
        <span>{t(locale, 'waitlist_form_email_label')}</span>
        <input
          type="email"
          name="email"
          placeholder={t(locale, 'waitlist_form_email_placeholder') ?? ''}
          autocomplete="email"
          required
        />
      </label>

      <label class="waitlist-field">
        <span>{t(locale, 'waitlist_form_role_label')}</span>
        <input
          type="text"
          name="role"
          placeholder={t(locale, 'waitlist_form_role_placeholder') ?? ''}
          autocomplete="organization-title"
        />
      </label>

      <label class="waitlist-field waitlist-field-wide">
        <span>{t(locale, 'waitlist_form_use_case_label')}</span>
        <textarea
          name="useCase"
          placeholder={t(locale, 'waitlist_form_use_case_placeholder') ?? ''}
          rows={4}
        ></textarea>
      </label>

      <div class="waitlist-actions waitlist-field-wide">
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          class="waitlist-honeypot"
        />
        {
          turnstileSiteKey ? (
            <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
          ) : null
        }
        <button type="submit" class="btn btn-primary">{t(locale, 'waitlist_form_submit')}</button>
        <p class="waitlist-success" data-waitlist-success role="status" aria-live="polite" hidden>
          {t(locale, 'waitlist_form_success')}
        </p>
        <p class="waitlist-error" data-waitlist-error role="status" aria-live="polite" hidden>
          {t(locale, 'waitlist_form_error', false) ?? 'Submit failed. Please retry in a moment.'}
        </p>
      </div>
    </form>
  </article>
</section>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-waitlist-form]');
    if (!(form instanceof HTMLFormElement)) return;

    const success = form.querySelector('[data-waitlist-success]');
    const error = form.querySelector('[data-waitlist-error]');
    const submitButton = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;

      const email = (form.querySelector('input[name="email"]') as HTMLInputElement | null)?.value?.trim() ?? '';
      const name = (form.querySelector('input[name="name"]') as HTMLInputElement | null)?.value?.trim() ?? '';
      const role = (form.querySelector('input[name="role"]') as HTMLInputElement | null)?.value?.trim() ?? '';
      const useCase = (form.querySelector('textarea[name="useCase"]') as HTMLTextAreaElement | null)?.value?.trim() ?? '';
      const website = (form.querySelector('input[name="website"]') as HTMLInputElement | null)?.value ?? '';
      const turnstileToken =
        (form.querySelector('input[name="cf-turnstile-response"]') as HTMLInputElement | null)?.value ?? '';

      const sourcePath = window.location.pathname || '/';
      const language = sourcePath.startsWith('/zh') ? 'zh' : sourcePath.startsWith('/ja') ? 'ja' : 'en';

      if (success instanceof HTMLElement) success.hidden = true;
      if (error instanceof HTMLElement) error.hidden = true;
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;

      try {
        const response = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            name,
            role,
            useCase,
            language,
            sourcePath,
            website,
            turnstileToken,
          }),
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload?.ok) throw new Error(payload?.error || 'submit failed');

        form.dataset.submitted = 'true';
        form.reset();

        if (success instanceof HTMLElement) success.hidden = false;
        if (error instanceof HTMLElement) error.hidden = true;

        const turnstile = window.turnstile;
        if (turnstile && typeof turnstile.reset === 'function') {
          turnstile.reset();
        }
      } catch {
        if (error instanceof HTMLElement) error.hidden = false;
      } finally {
        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      }
    });
  })();
</script>

{
  turnstileSiteKey ? (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  ) : null
}
