---
import '../styles/global.css';
import instrumentSerif400 from '@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url';
import spaceGrotesk400 from '@fontsource/space-grotesk/files/space-grotesk-latin-400-normal.woff2?url';
import spaceGrotesk700 from '@fontsource/space-grotesk/files/space-grotesk-latin-700-normal.woff2?url';
import { localizePath, resolveLocale, stripLocalePrefix, t, type Locale } from '../i18n/runtime';
import { buildSeoLinks } from '../i18n/seo';
import { getLearnResourceTargets } from '../support/kb';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  noindex?: boolean;
}

const props = Astro.props as Props;
const locale = props.locale ?? resolveLocale(Astro.url.pathname);
const pageTitle = props.title ?? t(locale, 'meta_default_title') ?? 'FinDIT';
const pageDescription =
  props.description ??
  t(locale, 'meta_default_description') ??
  'FinDIT Studio delivers a fast, elegant operating layer for teams that execute with precision.';

const site = Astro.site?.toString() ?? 'https://findit.studio';
const seoLinks = buildSeoLinks(site, Astro.url.pathname, locale);
const ogImagePath = props.ogImage ?? '/og-default.svg';
const ogImageUrl = new URL(ogImagePath, site).toString();

const basePathRaw = stripLocalePrefix(Astro.url.pathname);
const basePath = basePathRaw !== '/' && basePathRaw.endsWith('/') ? basePathRaw.slice(0, -1) : basePathRaw;
const learnTargets = new Map(getLearnResourceTargets(locale).map((target) => [target.id, target.href]));

const navItems = [
  { path: '/', href: localizePath(locale, '/'), label: t(locale, 'nav_home') ?? 'Home' },
  { path: '/blog', href: localizePath(locale, '/blog'), label: t(locale, 'nav_blog') ?? 'Blog' },
  {
    path: '/support',
    href: localizePath(locale, '/support'),
    label: t(locale, 'nav_support') ?? 'Support',
  },
];

const resourcesSections = [
  {
    title: t(locale, 'nav_resources_group_learn') ?? 'Learn',
    links: [
      {
        label: t(locale, 'nav_resources_quick_start') ?? 'Quick Start',
        href: learnTargets.get('quick-start') ?? localizePath(locale, '/support'),
      },
      {
        label: t(locale, 'nav_resources_video_tutorials') ?? 'Video Tutorials',
        href: learnTargets.get('video-tutorials') ?? localizePath(locale, '/support'),
      },
      {
        label: t(locale, 'nav_resources_all_features') ?? 'All Features',
        href: learnTargets.get('all-features') ?? localizePath(locale, '/support'),
      },
    ],
  },
];
const resourcesIsSingleSection = resourcesSections.length === 1;
const currentYear = new Date().getFullYear();

function isActive(path: string): boolean {
  if (path === '/') return basePath === '/';
  return basePath === path || basePath.startsWith(`${path}/`);
}

const resourcesActive = isActive('/resources');
---

<html lang={locale === 'zh' ? 'zh-CN' : locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <link rel="canonical" href={seoLinks.canonical} />
    <link rel="alternate" hreflang="en" href={seoLinks.alternates.en} />
    <link rel="alternate" hreflang="zh-CN" href={seoLinks.alternates.zh} />
    <link rel="alternate" hreflang="x-default" href={seoLinks.alternates.en} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FinDIT" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={seoLinks.canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    {props.noindex ? <meta name="robots" content="noindex, nofollow" /> : null}

    <link rel="preload" href={spaceGrotesk400} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={spaceGrotesk700} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={instrumentSerif400} as="font" type="font/woff2" crossorigin="anonymous" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand-link" href={localizePath(locale, '/')}>{t(locale, 'brand_name') ?? 'FinDIT'}</a>

        <nav class="main-nav" aria-label="Primary">
          <a class:list={['nav-link', isActive('/') && 'is-active']} href={localizePath(locale, '/')}>
            {t(locale, 'nav_home') ?? 'Home'}
          </a>

          <a class:list={['nav-link', isActive('/blog') && 'is-active']} href={localizePath(locale, '/blog')}>
            {t(locale, 'nav_blog') ?? 'Blog'}
          </a>

          <a class:list={['nav-link', isActive('/pricing') && 'is-active']} href={localizePath(locale, '/pricing')}>
            {t(locale, 'nav_pricing') ?? 'Pricing'}
          </a>

          <div class:list={['nav-dropdown', resourcesActive && 'is-active']} data-nav-dropdown>
            <button
              class:list={['nav-link', 'nav-dropdown-trigger', resourcesActive && 'is-active']}
              data-nav-dropdown-trigger
              aria-haspopup="true"
              aria-expanded="false"
              type="button"
            >
              {t(locale, 'nav_resources') ?? 'Resources'}
              <span class="nav-caret" aria-hidden="true">▾</span>
            </button>

            <div class:list={['nav-dropdown-panel', resourcesIsSingleSection && 'is-single']} data-nav-dropdown-panel>
              <div class:list={['nav-dropdown-grid', resourcesIsSingleSection && 'is-single']}>
                {
                  resourcesSections.map((section) => (
                    <section class="nav-dropdown-col">
                      <h3>{section.title}</h3>
                      <ul>
                        {section.links.map((link) => (
                          <li>
                            <a
                              href={link.href}
                              target={link.external ? '_blank' : undefined}
                              rel={link.external ? 'noreferrer noopener' : undefined}
                            >
                              <span>{link.label}</span>
                              {link.external ? <span class="ext-mark">↗</span> : null}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </section>
                  ))
                }
              </div>
            </div>
          </div>

          <a
            class:list={['nav-link', isActive('/support') && 'is-active']}
            href={localizePath(locale, '/support')}
          >
            {t(locale, 'nav_support') ?? 'Support'}
          </a>
        </nav>

        <div class="lang-switch" aria-label="Language switcher">
          <span>{t(locale, 'nav_language') ?? 'Language'}</span>
          <a href={localizePath('en', basePath)}>EN</a>
          <span>/</span>
          <a href={localizePath('zh', basePath)}>中文</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <div class="site-footer-top">
          <section class="site-footer-brand">
            <a class="site-footer-logo" href={localizePath(locale, '/')}>{t(locale, 'brand_name') ?? 'FinDIT'}</a>
            <p class="site-footer-tagline">{t(locale, 'footer_tagline') ?? ''}</p>

            <div class="site-footer-social" aria-label="Social links">
              <a href="https://discord.gg/Y4TMsurPG9" target="_blank" rel="noreferrer noopener">Discord</a>
              <!-- <a href="https://x.com/" target="_blank" rel="noreferrer noopener">X</a> -->
              <!-- <a href="https://www.youtube.com/" target="_blank" rel="noreferrer noopener">YouTube</a> -->
              <!-- <a href="https://www.tiktok.com/" target="_blank" rel="noreferrer noopener">TikTok</a> -->
            </div>
          </section>

          <div class="site-footer-nav-grid">
            <section class="site-footer-col">
              <h2>{t(locale, 'footer_column_resources') ?? 'Resources'}</h2>
              <ul>
                <li><a href={localizePath(locale, '/blog')}>{t(locale, 'footer_link_blog') ?? 'Blog'}</a></li>
                <li><a href={localizePath(locale, '/support')}>{t(locale, 'footer_link_support') ?? 'Support'}</a></li>
                <li>
                  <a href="https://discord.gg/Y4TMsurPG9" target="_blank" rel="noreferrer noopener">
                    {t(locale, 'footer_link_discord') ?? 'Discord'}
                  </a>
                </li>
              </ul>
            </section>

            <section class="site-footer-col">
              <h2>{t(locale, 'footer_column_company') ?? 'Company'}</h2>
              <ul>
                <li>
                  <a href={`mailto:support@findit.studio`}>{t(locale, 'footer_link_contact') ?? 'Contact'}</a>
                </li>
                <!-- <li><a href="/careers">Careers</a></li> -->
              </ul>
            </section>

            <section class="site-footer-col">
              <h2>{t(locale, 'footer_column_product') ?? 'Product'}</h2>
              <ul>
                <li><a href={localizePath(locale, '/pricing')}>{t(locale, 'footer_link_pricing') ?? 'Pricing'}</a></li>
                <li><a href={localizePath(locale, '/waitlist')}>{t(locale, 'footer_link_waitlist') ?? 'Waitlist'}</a></li>
              </ul>
            </section>
          </div>
        </div>

        <div class="site-footer-bottom">
          <p>{t(locale, 'footer_rights')?.replace('{year}', String(currentYear)) ?? `© ${currentYear} FinDIT. All rights reserved.`}</p>
          <p class="site-footer-legal">
            <a href={localizePath(locale, '/privacy')}>{t(locale, 'footer_legal_privacy') ?? 'Privacy Policy'}</a>
            <a href={localizePath(locale, '/terms')}>{t(locale, 'footer_legal_terms') ?? 'Terms of Service'}</a>
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const dropdowns = document.querySelectorAll('[data-nav-dropdown]');

        const closeAll = () => {
          dropdowns.forEach((dropdown) => {
            dropdown.classList.remove('is-open');
            const trigger = dropdown.querySelector('[data-nav-dropdown-trigger]');
            if (trigger) trigger.setAttribute('aria-expanded', 'false');
          });
        };

        dropdowns.forEach((dropdown) => {
          const trigger = dropdown.querySelector('[data-nav-dropdown-trigger]');
          if (!(trigger instanceof HTMLButtonElement)) return;

          trigger.addEventListener('click', (event) => {
            event.preventDefault();
            const isOpen = dropdown.classList.contains('is-open');
            closeAll();
            if (!isOpen) {
              dropdown.classList.add('is-open');
              trigger.setAttribute('aria-expanded', 'true');
            }
          });
        });

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Node)) return;

          const insideDropdown = [...dropdowns].some((dropdown) => dropdown.contains(target));
          if (!insideDropdown) closeAll();
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeAll();
        });

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return;
        }

        document.documentElement.classList.add('js-motion');

        const targets = document.querySelectorAll('.reveal');
        if (!targets.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.2 },
        );

        targets.forEach((node) => observer.observe(node));
      })();
    </script>
  </body>
</html>
