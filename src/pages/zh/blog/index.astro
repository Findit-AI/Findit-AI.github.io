---
import { getCollection } from 'astro:content';
import MainLayout from '../../../layouts/MainLayout.astro';
import invalidContent from '../../../generated/content-invalid.json';
import { t } from '../../../i18n/runtime';
import { getCategoryName, getDateFormatter, getBlogSubtitle } from '../../../blog/blog-utils';

const locale = 'zh';
const blocked = new Set(invalidContent.invalidByCollection.blog ?? []);

const posts = (await getCollection('blog', ({ data }) => data.locale === locale && !data.draft))
  .filter((entry) => !blocked.has(entry.slug))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const formatDate = getDateFormatter(locale);
const subtitle = getBlogSubtitle(locale);
const categories = Array.from(new Set(posts.map((post) => getCategoryName(locale, post.data.category))));
---

<MainLayout locale={locale} title="FinDIT | 博客">
  <section class="blog-index-shell reveal">
    <header class="blog-index-head">
      <p class="section-kicker">Journal</p>
      <h1>{t(locale, 'page_blog_title')}</h1>
      <p>{subtitle}</p>

      {categories.length > 0 ? (
        <div class="blog-category-row" aria-label="博客分类">
          <button class="blog-category-chip is-active" data-category="all" type="button">全部</button>
          {categories.map((category) => <button class="blog-category-chip" data-category={category} type="button">{category}</button>)}
        </div>
      ) : null}
    </header>

    {
      posts.length === 0 ? (
        <p class="blog-empty">{t(locale, 'page_coming_soon')}</p>
      ) : (
        <div class="blog-list-grid">
          {posts.map((entry) => (
            <a class="blog-list-card" href={`/zh/blog/${entry.slug}`} data-card-category={getCategoryName(locale, entry.data.category)}>
              <p class="blog-list-card-meta">
                <span>{getCategoryName(locale, entry.data.category)}</span>
                <span aria-hidden="true">·</span>
                <span>{formatDate.format(entry.data.publishedAt)}</span>
              </p>
              <h2 class="blog-list-card-title">{entry.data.title}</h2>
              <p class="blog-list-card-desc">{entry.data.description}</p>
              <span class="blog-list-card-link">
                {t(locale, 'label_open_article')}
                <span aria-hidden="true">↗</span>
              </span>
            </a>
          ))}
        </div>
      )
    }
  </section>

  <script>
    const chips = document.querySelectorAll<HTMLButtonElement>('.blog-category-chip');
    const cards = document.querySelectorAll<HTMLAnchorElement>('.blog-list-card');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('is-active'));
        chip.classList.add('is-active');

        const category = chip.dataset.category;
        cards.forEach((card) => {
          if (category === 'all' || card.dataset.cardCategory === category) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</MainLayout>
