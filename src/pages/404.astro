---
import MainLayout from '../layouts/MainLayout.astro';
import { resolveLocale, t } from '../i18n/runtime';

const locale = resolveLocale(Astro.url.pathname);
const backHome = locale === 'zh' ? '/zh' : '/';
---

<MainLayout locale={locale} title="FinDIT | 404" noindex={true}>
  <section class="surface" style="padding: 44px; display: grid; gap: 14px;">
    <h1 style="font-size: 2rem;">{t(locale, 'error_not_found_title')}</h1>
    <p>{t(locale, 'error_not_found_body')}</p>
    <a href={backHome} style="display: inline-block; width: fit-content; border: 1px solid var(--surface-border); border-radius: 999px; padding: 10px 16px; text-decoration: none; color: var(--text-0);">
      {t(locale, 'error_back_home')}
    </a>
  </section>
</MainLayout>
